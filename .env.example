# App
APP_BASE_URL=https://your-vercel-project.vercel.app
AUTH_SECRET=replace-with-random-secret

# Database
DATABASE_URL=replace-with-neon-postgres-url

# Google OAuth for app login
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_ALLOWED_EMAILS=founder@example.com,teammate@example.com

# Google transcript pickup
# Use either local OAuth/ADC for personal/internal testing or delegated service
# account auth for a Workspace deployment.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_IMPERSONATE_USER=
GOOGLE_USE_METADATA_CREDENTIALS=false

# Agent API
KANBAN_AGENT_TOKEN=replace-with-random-agent-token

# Model provider
MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
AWS_REGION=

# Backups
KANBAN_BACKUP_INTERVAL_DAYS=7
KANBAN_BACKUP_RETENTION_DAYS=28
